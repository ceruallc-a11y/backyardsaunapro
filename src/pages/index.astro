---
import Base from '../layouts/Base.astro';
import AmazonButton from '../components/AmazonButton.astro';

const featuredPicks = [
  {
    asin: "B017WJV8SO",
    name: "Almost Heaven Pinnacle 2-Person Barrel Sauna",
    price: "$2,199",
    rating: "4.5/5",
    blurb: "Our top pick for most homeowners. Cedar construction, easy assembly, and impressive heat retention.",
    tag: "BEST OVERALL"
  },
  {
    asin: "B00A2F99F0",
    name: "Dynamic Saunas Barcelona 1-2 Person Far Infrared Sauna",
    price: "$899",
    rating: "4.4/5",
    blurb: "Best budget-friendly infrared option. Heats in 15 minutes, low EMF panels, compact footprint.",
    tag: "BEST BUDGET"
  },
  {
    asin: "B017WJV8SO",
    name: "Almost Heaven Pinnacle 4-Person Barrel Sauna",
    price: "$4,800",
    rating: "4.8/5",
    blurb: "Premium Canadian white cedar, built for decades. Worth every penny if you're serious about sauna.",
    tag: "BEST PREMIUM"
  }
];
---
<Base
  title="Backyard Sauna Pro — Best Outdoor Saunas Reviewed"
  description="Expert reviews and buying guides for backyard saunas. Find the best outdoor sauna for your home and budget."
  canonical="/"
>
  <!-- Hero -->
  <section class="text-center py-12">
    <h1 class="text-4xl md:text-5xl font-bold text-stone-900 mb-4">
      Find Your Perfect Backyard Sauna
    </h1>
    <p class="text-lg text-stone-600 max-w-2xl mx-auto mb-8">
      Honest, in-depth reviews and expert buying guides to help you choose the best outdoor sauna for your home, budget, and lifestyle.
    </p>
    <a href="/best-saunas" class="inline-block bg-stone-900 hover:bg-stone-700 text-white font-semibold px-8 py-4 rounded-lg transition-colors text-lg">
      See Our Top Picks →
    </a>
  </section>

  <!-- Featured Picks -->
  <section class="mt-12">
    <h2 class="text-2xl font-bold mb-6 text-stone-900">🏆 Our Top Picks for 2025</h2>
    <div class="grid md:grid-cols-3 gap-6">
      {featuredPicks.map(pick => (
        <div class="bg-white rounded-xl shadow p-6 border border-stone-200 flex flex-col">
          <span class="text-xs font-bold bg-amber-100 text-amber-800 px-2 py-1 rounded w-fit mb-3">{pick.tag}</span>
          <h3 class="font-semibold text-stone-900 mb-2 leading-snug">{pick.name}</h3>
          <p class="text-sm text-stone-600 flex-grow mb-3">{pick.blurb}</p>
          <p class="text-xs text-stone-400 mb-2">Rating: {pick.rating}</p>
          <AmazonButton asin={pick.asin} price={pick.price} />
        </div>
      ))}
    </div>
  </section>

  <!-- Content Sections -->
  <section class="mt-16">
    <h2 class="text-2xl font-bold mb-6 text-stone-900">📚 Buying Guides</h2>
    <div class="grid md:grid-cols-2 gap-4">
      {[
        ["/guides/infrared-vs-traditional-sauna", "Infrared vs Traditional Sauna", "The real differences, explained without the jargon."],
        ["/guides/best-electric-sauna-heaters", "Best Electric Sauna Heaters (2025)", "Ranked by quality, value, and cold-climate performance."],
        ["/guides/best-barrel-saunas-cold-climates", "Best Barrel Saunas for Cold Climates", "Winter-ready picks that handle extreme temps."],
        ["/guides/best-saunas-under-2000", "Best Saunas Under $2,000", "Real value options at every sub-$2k price point."],
        ["/guides/best-2-person-outdoor-sauna", "Best 2-Person Outdoor Sauna Kits", "Top picks for couples and smaller yards."],
        ["/guides/best-sauna-accessories", "Best Sauna Accessories for Beginners", "Everything you need for day one — prioritized."],
      ].map(([href, title, desc]) => (
        <a href={href} class="block bg-white border border-stone-200 rounded-xl p-4 hover:border-amber-400 hover:shadow transition-all">
          <p class="font-semibold text-stone-900 text-sm">{title}</p>
          <p class="text-xs text-stone-500 mt-1">{desc}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-2xl font-bold mb-6 text-stone-900">🔧 Planning & Installation</h2>
    <div class="grid md:grid-cols-2 gap-4">
      {[
        ["/guides/how-much-space-for-backyard-sauna", "How Much Space Do You Need?", "Dimensions, clearances, and footprint planning."],
        ["/guides/best-location-backyard-sauna", "Best Location for a Backyard Sauna", "Drainage, privacy, sun exposure, and more."],
        ["/guides/sauna-foundation-guide", "Sauna Foundation Guide", "Concrete, gravel, timber — all options compared."],
        ["/guides/sauna-electrical-requirements", "Sauna Electrical Requirements", "Circuit sizes, costs, and permit requirements."],
        ["/guides/how-to-assemble-barrel-sauna", "How to Assemble a Barrel Sauna", "Step-by-step from unboxing to first heat."],
        ["/guides/sauna-maintenance-guide", "Sauna Maintenance Guide", "Keep your sauna lasting 20–40 years."],
      ].map(([href, title, desc]) => (
        <a href={href} class="block bg-white border border-stone-200 rounded-xl p-4 hover:border-amber-400 hover:shadow transition-all">
          <p class="font-semibold text-stone-900 text-sm">{title}</p>
          <p class="text-xs text-stone-500 mt-1">{desc}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-2xl font-bold mb-6 text-stone-900">⚖️ Comparisons</h2>
    <div class="grid md:grid-cols-2 gap-4">
      {[
        ["/guides/barrel-sauna-vs-cabin-sauna", "Barrel Sauna vs Cabin Sauna", "Heat efficiency, cost, and which to choose."],
        ["/guides/electric-vs-wood-fired-sauna", "Electric vs Wood-Fired Sauna", "Convenience vs authenticity — the honest comparison."],
      ].map(([href, title, desc]) => (
        <a href={href} class="block bg-white border border-stone-200 rounded-xl p-4 hover:border-amber-400 hover:shadow transition-all">
          <p class="font-semibold text-stone-900 text-sm">{title}</p>
          <p class="text-xs text-stone-500 mt-1">{desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Trust signals -->
  <section class="mt-16 bg-stone-100 rounded-xl p-8 text-center">
    <h2 class="text-xl font-bold mb-2 text-stone-900">Why Trust Us?</h2>
    <p class="text-stone-600 max-w-2xl mx-auto">
      We research every sauna we recommend — specs, real customer reviews, manufacturer reputation, and long-term durability. We only recommend products we'd genuinely buy ourselves. Our affiliate links support this site at no extra cost to you.
    </p>
  </section>
</Base>
