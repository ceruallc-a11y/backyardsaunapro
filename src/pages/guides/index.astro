    items: [
      { href: "/guides/how-much-space-for-backyard-sauna", title: "How Much Space Do You Need?", desc: "Dimensions, clearances, and footprint planning." },
      { href: "/guides/best-location-backyard-sauna", title: "Best Location for a Backyard Sauna", desc: "Drainage, privacy, sun exposure, and codes." },
      { href: "/guides/sauna-foundation-guide", title: "Sauna Foundation Guide", desc: "Concrete, gravel, timber all options compared." },
      { href: "/guides/sauna-electrical-requirements", title: "Sauna Electrical Requirements", desc: "Circuit sizes, costs, and permit requirements." },
