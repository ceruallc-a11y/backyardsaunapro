    ]
  },
  {
    category: "Materials & Accessories",
    
    items: [
      { href: "/guides/cedar-vs-hemlock-sauna", title: "Cedar vs Hemlock Sauna: Which Wood Is Better?", desc: "Durability, smell, cost, and which to choose." },
