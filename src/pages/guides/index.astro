  {
    category: "Permits & Regulations",
    
    items: [
      { href: "/guides/outdoor-sauna-permits", title: "Do You Need a Permit for an Outdoor Sauna?", desc: "Building permits, zoning rules, setbacks, and HOA requirements." },
    ]
  },
  {
    category: "Health & Wellness",
    
    items: [
      { href: "/guides/sauna-health-benefits", title: "Sauna Health Benefits: What Science Says", desc: "The evidence behind cardiovascular, recovery, and sleep benefits." },
