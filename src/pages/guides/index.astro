---
<Base
  title="Sauna Guides Backyard Sauna Pro"
  description="All sauna buying guides, planning guides, installation guides, and comparisons from Backyard Sauna Pro."
  canonical="/guides"
>
  <div class="max-w-3xl mx-auto">
    <h1 class="text-4xl font-bold text-stone-900 mb-2">Sauna Guides</h1>
    <p class="text-stone-500 mb-10">Everything you need to buy, plan, install, and maintain a backyard sauna.</p>

    {guides.map(section => (
      <section class="mb-10">
        <h2 class="text-xl font-bold text-stone-900 mb-4">{section.category}</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {section.items.map(item => (
            <a href={item.href} class="block bg-white border border-stone-200 rounded-xl p-4 hover:border-amber-400 hover:shadow transition-all">
              <p class="font-semibold text-stone-900 text-sm">{item.title}</p>
              <p class="text-xs text-stone-500 mt-1">{item.desc}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</Base>
