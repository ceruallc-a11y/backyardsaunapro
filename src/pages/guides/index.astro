      { href: "/guides/best-2-person-outdoor-sauna", title: "Best 2-Person Outdoor Sauna Kits", desc: "Top picks for couples and smaller yards." },
      { href: "/guides/best-sauna-accessories", title: "Best Sauna Accessories for Beginners", desc: "Everything you need for day one." },
    ]
