---
export interface Props {
  asin: string;
  label?: string;
  price?: string;
}
const { asin, label = "Check Price on Amazon", price: _price } = Astro.props;
const tag = "backyardsauna-20";
const url = `https://www.amazon.com/dp/${asin}?tag=${tag}`;
---
<div class="my-4">
  <a
    href={url}
    target="_blank"
    rel="nofollow noopener sponsored"
    class="inline-block bg-amber-400 hover:bg-amber-500 text-stone-900 font-semibold px-6 py-3 rounded-lg transition-colors shadow"
  >
    {label} &rarr;
  </a>
</div>
